{
  "name": "ci-pipeline",
  "version": "0.0.1",
  "description": "Dagger TypeScript CI pipeline — typecheck, lint, test, security, build",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "dagger develop",
    "ci": "dagger call ci",
    "build": "dagger call build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@dagger.io/dagger": "^0.18.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11"
    }
  }
}
